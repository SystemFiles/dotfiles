# -*-mode:toml-*- vim:ft=toml
#:schema https://docs.jj-vcs.dev/latest/config-schema.json
# ~/.jjconfig.toml
# =============================================================================
# Jujutsu (jj) configuration. jj is the primary VCS on this machine.
# ~/.gitconfig stays as the colocated-backend identity/LFS/credential layer.
#
# Reference: https://docs.jj-vcs.dev/latest/config/
#
# {{- /* This file supports Go's text/template language. */ -}}
#

# User identity
# =============================================================================
[user]
name  = "{{ if .git_user }}{{ .git_user }}{{ else }}{{ .git_username }}{{ end }}"
email = "{{ .email }}"

# Git backend (colocated)
# =============================================================================
[git]
# Colocated with git so gh/glab/IDE tools keep working on the same repo.
colocate = true
# Defer signing until push: fast local rewrites, signed only when it matters.
sign-on-push = true
# Prevent `jj git push` from pushing WIP or private commits.
# Any commit whose description matches is filtered out of the push set.
private-commits = 'description(glob:"wip:*") | description(glob:"WIP:*") | description(glob:"private:*")'

# Track all remote bookmarks locally on fetch (replaces the deprecated
# `git.auto-local-bookmark`). Add a `[remotes.<name>]` block per remote as
# needed; `origin` covers the common case.
[remotes.origin]
auto-track-bookmarks = "*"

# Commit signing (SSH — mirrors ~/.gitconfig gpg.format = ssh)
# =============================================================================
[signing]
behavior = "own"
backend  = "ssh"
key      = "{{ .chezmoi.homeDir }}/.ssh/id_ed25519.pub"

# UI
# =============================================================================
[ui]
# Running `jj` with no args shows the log.
default-command = ["log"]
color           = "auto"
pager           = "less -FRX"

# Color-words diff: inline per-word coloring (replaces git diff.colorMoved).
diff-formatter = ":color-words"

# Diff-style conflict markers (cleaner than snapshot; equivalent to git zdiff3).
conflict-marker-style = "diff"

# Most-recent-commit first (equivalent to git branch.sort = -committerdate).
# Note: jj uses a *trailing* `-` suffix for descending order, not a leading `-`.
bookmark-list-sort-keys = ["committer-date-"]

# Readable log rendering on narrow terminals.
log-word-wrap              = true
log-synthetic-elided-nodes = true

[diff.color-words]
context                = 3
max-inline-alternation = 3

# Snapshot (working-copy auto-tracking)
# =============================================================================
[snapshot]
# Equivalent to `git add -A` running on every jj command.
auto-track = "all()"
# Guardrail: don't auto-snapshot files bigger than 1 MiB.
max-new-file-size = 1048576

# Revset aliases — named queries used across the config and shell aliases.
# =============================================================================
[revset-aliases]
# Robust trunk detection: whichever of main/master/trunk exists on origin.
'trunk()' = 'present(main@origin) | present(master@origin) | present(trunk@origin)'
# Commits that are mine, non-empty, and not marked WIP — safe to push.
'ready()' = 'mine() & ~empty() & ~description(regex:"(?i)^wip")'
# Work-in-progress commits — blocked from push by git.private-commits.
'wip()'   = 'mine() & description(regex:"(?i)^wip")'
# Current stack from trunk up to the working copy.
'stack()' = 'trunk()..@'
# All mutable (not-yet-immutable) commits.
'mut()'   = 'mutable()'
# My unpushed work — not yet in trunk ancestry.
'open()'  = 'mine() & ~::trunk()'

# Template aliases
# =============================================================================
[template-aliases]
'format_short_id(id)' = 'id.shortest(8)'

# Templates
# =============================================================================
[templates]
# Include diff in the commit-message editor (like git commit.verbose = true).
draft_commit_description = '''
concat(
  builtin_draft_commit_description,
  "\nJJ: ignore-rest\n",
  diff.stat(72),
  "\n",
  diff.git(),
)
'''

# Append Signed-off-by trailer automatically.
commit_trailers = 'format_signed_off_by_trailer(self)'

# In-app aliases (callable as `jj <alias>`)
# =============================================================================
[aliases]
l  = ["log", "-r", "@-..@"]
ls = ["log", "-r", "stack()"]
la = ["log", "-r", "all()"]
s  = ["status"]
d  = ["describe"]
n  = ["new"]
sq = ["squash"]
sp = ["split"]
di = ["diff"]
dc = ["diff", "-r", "@"]
ab = ["absorb"]
rt = ["rebase", "-d", "trunk()"]
f  = ["git", "fetch", "--all-remotes"]
p  = ["git", "push"]
u  = ["undo"]
ol = ["op", "log"]

# Colors
# =============================================================================
[colors]
"diff removed"           = { fg = "red" }
"diff added"             = { fg = "green" }
"diff removed token"     = { fg = "bright red",   bold = true }
"diff added token"       = { fg = "bright green", bold = true }
"working_copy"           = { bold = true }
"working_copy change_id" = { fg = "bright magenta", bold = true }
"working_copy commit_id" = { fg = "bright blue",    bold = true }
"bookmark"               = { fg = "bright cyan" }
"bookmarks"              = { fg = "bright cyan" }
"commit_id"              = { fg = "blue" }
"change_id"              = { fg = "magenta" }
"author"                 = { fg = "yellow" }
"timestamp"              = { fg = "cyan" }
"description"            = { fg = "white" }
"empty"                  = { fg = "bright black" }
"conflict"               = { fg = "bright red", bold = true }

